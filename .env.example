# Copy to .env and fill in. The demo runs fully WITHOUT a key (offline fallback
# uses the real assessor verdicts from the sample), but set this to see live Claude.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Postgres (used by docker-compose; Phase 2+ persistence)
DATABASE_URL=postgres://tprm:tprm@db:5432/tprm
